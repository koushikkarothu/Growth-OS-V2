<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="16dp"
    android:theme="@style/Theme.AppCompat.DayNight">

    <!-- HEADER: Title & XP Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMMANDER"
            android:textColor="#888888"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="XP 450/1000"
            android:textColor="#4CAF50"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"/>

        <ProgressBar
            android:id="@+id/widget_xp_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="80dp"
            android:layout_height="8dp"
            android:max="1000"
            android:progress="450"
            android:progressTint="#4CAF50"
            android:progressBackgroundTint="#333333"/>
    </LinearLayout>

    <!-- MAIN BODY: Active Focus -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingTop="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACTIVE FOCUS"
            android:textColor="#BB86FC"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_focus_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IELTS Writing Task 2"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/widget_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 12 Day Streak"
            android:textColor="#FFA000"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- ACTION TRAY: Quick Launch Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom">

        <Button
            android:id="@+id/btn_action_audio"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:backgroundTint="#2D2F31"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:text="🎙️ Note"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_action_text"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:backgroundTint="#2D2F31"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:text="📝 Text"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_action_dive"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:backgroundTint="#4CAF50"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="12sp"
            android:text="Deep Dive"/>
    </LinearLayout>
</LinearLayout>